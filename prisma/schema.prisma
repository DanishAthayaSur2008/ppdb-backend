generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// ENUMS
// =======================

enum Role {
  USER
  ADMIN
}

enum RegStatus {
  PENDING
  REJECTED
  VERIFIED
}

enum FormProgress {
  DRAFT
  SUBMITTED
  LOCKED
}

enum SelectionStage {
  PENDAFTARAN
  SELEKSI_BERKAS
  TES_AKADEMIK
  WAWANCARA
  PSIKOTEST
  HOME_VISIT
  PENGUMUMAN
}

enum SelectionResult {
  LULUS
  TIDAK_LULUS
  DALAM_PROSES
}

enum DocStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocType {
  RAPORT // Dokumen Nilai Raport Semester 3–5
  SKTM // Surat Keterangan Tidak Mampu
  FOLLOW_IG // Screenshot bukti follow IG
  VIDEO_REELS // Screenshot/link video reels
  SURAT_REKOMENDASI // Surat rekomendasi guru SMP
  AKTE_KELAHIRAN // Scan/foto Akte kelahiran
  KARTU_KELUARGA // Scan/foto Kartu Keluarga
  PAS_FOTO // Pas foto 3x4 terbaru
  BPJS_KIS // Scan/foto BPJS/KIS (jika ada)
  KIP // Scan/foto KIP (jika ada)
  FOTO_RUMAH_TAMPAK // Foto keseluruhan tampak rumah
  FOTO_KAMAR_TIDUR // Foto kamar tidur
  FOTO_DAPUR_KAMAR_MANDI // Foto dapur/kamar mandi
}

enum NotificationType {
  SYSTEM
  ADMIN_NOTE
  STATUS_UPDATE
  VERIFICATION
}

// =======================
// MODELS
// =======================

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  password          String
  role              Role      @default(USER)
  refreshToken      String?
  resetToken        String?
  resetTokenExpires DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relasi
  registrations         Registration[]
  verifiedRegistrations Registration[] @relation("VerifiedByAdmin")
  verifiedDocuments     Document[]     @relation("DocumentVerifier")
  notifications         Notification[]
  auditLogs             AuditLog[]
}

// =======================
// FORM PENDAFTARAN
// =======================

model Registration {
  id              Int              @id @default(autoincrement())
  userId          Int
  status          RegStatus        @default(PENDING)
  progress        FormProgress     @default(DRAFT)
  stage           SelectionStage   @default(PENDAFTARAN)
  selectionResult SelectionResult? @default(DALAM_PROSES)
  adminNote       String?
  verifiedBy      Int?
  formData        Json
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  participantName String? // Nama peserta (diambil dari formData.personal.namaLengkap)
  nisn            String? // NISN (diambil dari formData.personal.nisn)

  user      User       @relation(fields: [userId], references: [id])
  admin     User?      @relation("VerifiedByAdmin", fields: [verifiedBy], references: [id])
  documents Document[]
  auditLogs AuditLog[]
}

// =======================
// DOKUMEN / BERKAS UPLOAD
// =======================

model Document {
  id             Int       @id @default(autoincrement())
  registrationId Int
  docType        DocType
  fileName       String
  originalName   String
  mimeType       String
  size           Int
  status         DocStatus @default(PENDING)
  note           String?
  verifiedBy     Int?
  createdAt      DateTime  @default(now())

  registration Registration @relation(fields: [registrationId], references: [id])
  admin        User?        @relation("DocumentVerifier", fields: [verifiedBy], references: [id])

  @@unique([registrationId, docType]) // ✅ Hanya satu file per jenis dokumen
}

// =======================
// NOTIFIKASI
// =======================

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}

// =======================
// AUDIT LOG
// =======================

model AuditLog {
  id             Int      @id @default(autoincrement())
  userId         Int?
  registrationId Int?
  action         String
  details        String?
  ip             String?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  registration Registration? @relation(fields: [registrationId], references: [id])
}
